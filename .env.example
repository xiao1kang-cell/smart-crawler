# smart-crawler 环境变量模板 —— 复制为 .env 并填入真实值
# cp .env.example .env
#
# 多环境约定：
# - 本机直接启动默认读取 .env.test（旧平台风格：默认测试）
# - APP_ENV=test 读取 .env.test
# - APP_ENV=production 或 APP_ENV=prod 读取 .env.production
# - SC_ENV_FILE=/abs/path/to/file 或 ENV_FILE=/abs/path/to/file 可显式指定配置文件
# - SC_EXTRA_ENV_FILE=backend/app/crawlers/amazon_crawler/secrets/amazon-voc.test.env 可拆出 Amazon VOC 私密配置
# - 本机/线上 worker 不走 Docker 时，DATABASE_URL 主机写 NAS/Tailscale IP
# - Docker Compose 文件内部仍可使用 postgres/redis service name 作为容器网络默认值

# PostgreSQL（服务化部署主数据库）
POSTGRES_USER=smart_crawler
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=smart_crawler
DATABASE_URL=postgresql+psycopg://smart_crawler:change-me-strong-password@100.116.163.64:5432/smart_crawler

# 应用密钥（Token 签名）
SC_SECRET=change-me-random-secret

# 管理员账号（看板登录）
# ADMIN_PASSWORD 只在首次创建账号时生效；之后在控制台改的密码不会被部署覆盖。
# 忘记密码需找回时：临时设 ADMIN_PASSWORD_FORCE_RESET=1 启动一次，再去掉。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
# ADMIN_PASSWORD_FORCE_RESET=1

# LLM 网关（NLP 分析 / VOC 报告）—— flatkey OpenAI 兼容代理
OPENAI_API_KEY=
LLM_BASE_URL=https://router.flatkey.ai/v1
LLM_MODEL=gpt-5-mini

# Amazon VOC 工具 —— apps.voc.ai/openapi 免费注册
VOC_API_KEY=
# 推荐：真实 Amazon VOC 密钥放在 backend/app/crawlers/amazon_crawler/secrets/amazon-voc.*.env，
# 再由根 env 的 SC_EXTRA_ENV_FILE 引入。
# SC_EXTRA_ENV_FILE=backend/app/crawlers/amazon_crawler/secrets/amazon-voc.test.env

# Generic Amazon Review/Listing integration
# X-Token used by Anker-compatible routes: /job/submit and /job/result.
# Prefer tenant-level tokens in production. AMAZON_VOC_TOKEN is only a global fallback.
AMAZON_VOC_TOKEN=
# JSON format:
#   AMAZON_VOC_TENANT_TOKENS={"anker_001":"sec_xxx","other_tenant":"sec_yyy"}
# Or simple pair format:
#   AMAZON_VOC_TENANT_TOKENS=anker_001=sec_xxx,other_tenant=sec_yyy
AMAZON_VOC_TENANT_TOKENS=
# Tenant-level default callbacks. Request callback/callback_url wins when provided.
# JSON format:
#   AMAZON_VOC_TENANT_CALLBACK_URLS={"anker_001":"https://example.com/amazon/voc/callback"}
# Or simple pair format:
#   AMAZON_VOC_TENANT_CALLBACK_URLS=anker_001=https://example.com/amazon/voc/callback,other_tenant=https://example.com/other
AMAZON_VOC_TENANT_CALLBACK_URLS=
# Public base URL used when OSS is not configured and smart-crawler serves local result URLs.
AMAZON_VOC_PUBLIC_BASE_URL=
# Redis scheduling queue for high-volume Amazon Review/Listing jobs.
AMAZON_VOC_REDIS_URL=redis://:change-me-redis-password@100.116.163.64:6380/0
AMAZON_VOC_QUEUE_PREFIX=amazon:voc
AMAZON_VOC_RESULT_PREFIX=crawler-data
AMAZON_VOC_DEFAULT_TENANT=default
# Optional callback secret sent as X-Callback-Secret when pushing task results.
AMAZON_VOC_CALLBACK_SECRET=
# Amazon execution account pool. Production should keep REQUIRE_ACCOUNT=1 and
# import rows into amazon_crawler_accounts in Postgres.
AMAZON_VOC_REQUIRE_ACCOUNT=1
AMAZON_VOC_ALLOW_ANONYMOUS=0
# Legacy routing rule: proxies containing this marker use curl_cffi; other
# account proxies use fingerprint browser vendors below.
AMAZON_VOC_CURL_PROXY_MARKER=zone-custom-region-
AMAZON_VOC_USE_LEGACY_FETCH=1
AMAZON_VOC_HTTP_TIMEOUT_SECONDS=30
AMAZON_VOC_ACCOUNT_SUCCESS_COOLDOWN_SECONDS=30
AMAZON_VOC_ACCOUNT_FAILURE_COOLDOWN_SECONDS=300
AMAZON_VOC_ACCOUNT_BLOCK_COOLDOWN_SECONDS=1800
AMAZON_VOC_ACCOUNT_NETWORK_COOLDOWN_SECONDS=120
AMAZON_VOC_ACCOUNT_LOGIN_COOLDOWN_SECONDS=86400
AMAZON_VOC_ACCOUNT_MAX_FAILS=5
# Account lock/session policy. STALE_LOCK releases rows stuck in is_used=1;
# SESSION_STICKY lets the same worker reuse one account briefly across retries.
AMAZON_VOC_ACCOUNT_STALE_LOCK_SECONDS=900
AMAZON_VOC_ACCOUNT_SESSION_STICKY_SECONDS=600
AMAZON_VOC_ACCOUNT_SESSION_TASK_LIMIT=8
AMAZON_VOC_ACCOUNT_SESSION_REST_MIN_SECONDS=600
AMAZON_VOC_ACCOUNT_SESSION_REST_MAX_SECONDS=1200
# Account/browser session idle recovery timeout, not single task timeout.
AMAZON_VOC_SESSION_IDLE_TIMEOUT_SECONDS=900
# 0 means unlimited. Set later when the Postgres account pool has enough rows.
AMAZON_VOC_ACCOUNT_HOURLY_TASK_LIMIT=0
AMAZON_VOC_ACCOUNT_DAILY_TASK_LIMIT=0
AMAZON_VOC_ACCOUNT_HOURLY_PAGE_LIMIT=0
AMAZON_VOC_ACCOUNT_DAILY_PAGE_LIMIT=0
AMAZON_VOC_ACCOUNT_DAY_STATS_PREFIX=acc_day
AMAZON_VOC_ACCOUNT_HOUR_STATS_PREFIX=acc_hour
AMAZON_VOC_ACCOUNT_DAY_STATS_TTL_SECONDS=172800
AMAZON_VOC_ACCOUNT_HOUR_STATS_TTL_SECONDS=10800
# Production should keep this enabled: if Redis account counters are unavailable,
# workers should not claim accounts because quota protection would be blind.
AMAZON_VOC_REDIS_ACCOUNT_LIMITS_REQUIRED=1
# Listing/detail jobs do not use Amazon accounts; they lease a proxy endpoint.
# Use pool:all by default, or configure a dedicated pool such as pool:amazon_listing.
AMAZON_VOC_LISTING_PROXY_TIER=pool:all
AMAZON_VOC_LISTING_PROXY_LEASE_TTL_SECONDS=90
AMAZON_VOC_REVIEW_PROXY_LEASE_TTL_SECONDS=900
AMAZON_VOC_PROXY_HOURLY_LIMIT=40
AMAZON_VOC_PROXY_DAILY_LIMIT=400
AMAZON_VOC_NO_ACCOUNT_REQUEUE_SECONDS=20
# Single crawl task hard timeout.
AMAZON_VOC_TASK_HARD_TIMEOUT_SECONDS=480
# Dedicated Amazon worker process should keep this enabled so PM2/Docker restarts it.
AMAZON_VOC_TASK_HARD_TIMEOUT_EXIT=1
AMAZON_VOC_TASK_HEARTBEAT_INTERVAL_SECONDS=30
AMAZON_VOC_WORKER_STALE_HEARTBEAT_SECONDS=120
# Optional worker routing. Empty means this worker can consume all Amazon VOC jobs.
# Examples:
#   listing worker:    AmazonListingJob / all markets
#   US review worker:  AmazonReviewJob / US
#   global reviews:    AmazonReviewJob / exclude US
AMAZON_VOC_WORKER_JOB_TYPES=
AMAZON_VOC_WORKER_MARKETS=
AMAZON_VOC_WORKER_EXCLUDE_MARKETS=
# Local task_worker.py role split. If any of these is >0, it ignores
# AMAZON_VOC_WORKER_PROCESSES and starts role-specific worker processes.
AMAZON_VOC_WORKER_PROCESSES=4
AMAZON_VOC_LISTING_WORKER_PROCESSES=0
AMAZON_VOC_REVIEW_US_WORKER_PROCESSES=0
AMAZON_VOC_REVIEW_GLOBAL_WORKER_PROCESSES=0
AMAZON_VOC_REAPER_INTERVAL_SECONDS=30
AMAZON_VOC_CALLBACK_RETRY_INTERVAL_SECONDS=60
AMAZON_VOC_CALLBACK_RETRY_MIN_INTERVAL_SECONDS=300
AMAZON_VOC_CALLBACK_RETRY_MAX_ATTEMPTS=5
AMAZON_VOC_CALLBACK_RETRY_BATCH_SIZE=50
# Infrastructure daemon: event log, ban analyzer, aggregation, queue depth and watchdog.
AMAZON_VOC_LOG_DIR=
AMAZON_VOC_LOG_RETENTION_DAYS=7
AMAZON_VOC_DAEMON_HEARTBEAT_KEY=crawler:daemon:heartbeat
AMAZON_VOC_DAEMON_HEARTBEAT_INTERVAL_SECONDS=10
AMAZON_VOC_DAEMON_HEARTBEAT_TTL_SECONDS=30
AMAZON_VOC_API_WATCHDOG_URL=
AMAZON_VOC_QUEUE_DEPTH_INTERVAL_SECONDS=30
AMAZON_VOC_QUEUE_DEPTH_RETAIN_HOURS=72
AMAZON_VOC_QUEUE_DEPTH_WARN_TOTAL=100000
AMAZON_VOC_QUEUE_DEPTH_CRITICAL_TOTAL=300000
AMAZON_VOC_QUEUE_DEPTH_WARN_REVIEW=60000
AMAZON_VOC_QUEUE_DEPTH_WARN_LISTING=60000
AMAZON_VOC_WORKER_QUEUE_ALERT_MIN_DEPTH=50
AMAZON_VOC_BACKFILL_INTERVAL_SECONDS=60
AMAZON_VOC_BACKFILL_MAX_SCAN_ROWS=20000
AMAZON_VOC_DAILY_AGGREGATION_INTERVAL_SECONDS=3600
AMAZON_VOC_EVENT_LOG_RETENTION_DAYS=3
AMAZON_VOC_USAGE_LOG_RETENTION_DAYS=90
AMAZON_VOC_BAN_ANALYZE_INTERVAL_SECONDS=300
AMAZON_VOC_BAN_LOOKBACK_MINUTES=60
AMAZON_VOC_BROWSER_VENDOR_CHAIN=bit,tge,local_playwright
AMAZON_VOC_BROWSER_TTL_SECONDS=600
AMAZON_VOC_BROWSER_HEADLESS=1
AMAZON_VOC_BROWSER_CONCURRENT_LIMIT=3
AMAZON_VOC_BIT_API_URL=http://127.0.0.1:54345
AMAZON_VOC_BIT_API_KEY=
AMAZON_VOC_TGE_API_URL=
AMAZON_VOC_TGE_API_KEY=
# Optional OSS config. If empty, results are served through /parse/unpack/LOCAL/{hex_path}.
AMAZON_VOC_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
AMAZON_VOC_OSS_BUCKET=
AMAZON_VOC_OSS_ACCESS_KEY_ID=
AMAZON_VOC_OSS_ACCESS_KEY_SECRET=

# Cloudflare Tunnel（smartcrawler.io 接入）
TUNNEL_TOKEN=

# 定时采集 worker 并发 + 内存安全闸
# WORKER_THREADS：进程内 worker 线程数(每线程跑一个真浏览器)。默认 1。
#   调高可提速,但每个浏览器吃 300-800MB,小内存机器配合下面的内存闸使用。
# WORKER_THREADS=1
#
# 内存自适应并发闸 —— 主机已用内存 ≥ MEM_GATE_THRESHOLD% 时,worker 暂停领新 job
# (不起新浏览器),内存回落自动恢复。读 /proc/meminfo,读不到则放行(fail-open)。
# 设 0 或 100 关闸。
MEM_GATE_THRESHOLD=80
# MEM_GATE_CHECK_INTERVAL=2     # 闸内查内存间隔(秒)
# MEM_GATE_MAX_WAIT=300         # 单轮最多等待(秒),超时回循环重判
